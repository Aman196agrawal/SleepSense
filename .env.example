# ── Copy this to .env and fill in values ──────────────────────────────────────

# Shared secret (must match across all services)
SECRET_KEY=change-me-in-production-use-32-random-chars!!

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/sleepsense

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth Service ───────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── InfluxDB ───────────────────────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=dev-influxdb-token-sleepsense-2024
INFLUXDB_ORG=sleepsense
INFLUXDB_BUCKET=snore_events

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MinIO / S3 ─────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio-chunks
