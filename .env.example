# ── Copy this to .env and fill in values ──────────────────────────────────────
# REQUIRED values have no default in code — services will fail to start unless
# provided.

# Shared JWT signing secret (must match across all services, ≥32 random chars).
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_WITH_RANDOM_32_PLUS_CHAR_STRING

# CORS allowlist — comma-separated origins. Use the Expo dev server URL during
# local dev; switch to your production web origin in deployed envs.
# Set to "*" only for throw-away local testing (credentials will be disabled).
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/sleepsense

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth Service ───────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Analytics → Auth service base URL (used for inter-service user-existence check)
AUTH_SERVICE_URL=http://auth-service:8001

# ── InfluxDB ───────────────────────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
# Required when INFLUXDB_URL is set — no default. Generate via Influx UI/CLI.
INFLUXDB_TOKEN=REPLACE_WITH_GENERATED_TOKEN
INFLUXDB_ORG=sleepsense
INFLUXDB_BUCKET=snore_events

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MinIO / S3 ─────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio-chunks
